# Copy to .env and fill in. Never commit .env.

# FAC (api.fac.gov) — free key from https://api.data.gov/signup/
# Send as HTTP header: X-Api-Key: <key>
# PostgREST filters need operators, e.g. auditee_uei=eq.ABC123
FAC_API_KEY=

# SAM.gov — key from SAM.gov Account Details (re-enter password to view)
# PUBLIC extracts only (personal key). FOUO/SENSITIVE need federal system accounts.
#
# Preferred (1–2 GETs, then local lookups):
#   npm run sam:sync-exclusions
#     GET .../extracts?fileType=EXCLUSION&sensitivity=PUBLIC
#   npm run sam:sync-entities
#     GET .../extracts?fileType=ENTITY&sensitivity=PUBLIC&frequency=MONTHLY&date=MM/YYYY
#     → .cache/sam/entities.sqlite  (pipe-delimited V2; skips BOF/EOF lines)
#
# Optional live Entity API (burns ~10/day on free personal keys):
# SAM_LIVE_FALLBACK=0
#
# Prod: prefer bundled data/sam + Release (no SAM calls from the web dyno)
# SAM_DOWNLOAD_EXTRACTS=0
# SAM_ENTITY_DB_URL=https://github.com/OWNER/REPO/releases/download/sam-data-latest/entities.sqlite
#
# Keys expire every ~90 days; regenerate on SAM if rejected
SAM_API_KEY=

# Shared cache (recommended for Render free tier)
# Create free Redis at https://console.upstash.com → Redis → Create
# Copy REST URL + REST TOKEN from the REST API panel (not redis://)
# Full host required, e.g. https://dashing-duck-xxxxx.upstash.io  (must end in .io)
# UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Without these, cache is local disk only. Score map keys look like gfw:sc:v1:…
#
# Precalc (writes scores to Redis without hitting Render):
#   npm run scores:precalc
#   npm run scores:precalc -- --force
# CI: Actions secrets UPSTASH_* + FAC_API_KEY → workflow "Precalc scores"

# Soft wall-clock for enrichment after awards land (ms). Default 45000.
# ENRICH_BUDGET_MS=45000
# API pagination: GET /api/facilities?page=1&pageSize=20 (max 50).
# Speed path (still free / accuracy-preserving):
#   broad state+type → 4 award pages, no transactions, no subawards/CFDA baselines
#   list FAC = 1 HTTP (flags); full findings on rescore/deep dive
#   top 8 orgs/page get full grant hydrate (rest show · sample)

