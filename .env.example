# Copy to .env and fill in. Never commit .env.

# FAC (api.fac.gov) — free key from https://api.data.gov/signup/
# Send as HTTP header: X-Api-Key: <key>
# PostgREST filters need operators, e.g. auditee_uei=eq.ABC123
FAC_API_KEY=

# SAM.gov Entity API — key from SAM.gov Account Details (re-enter password to view)
# Send as query param: ?api_key=<key>
# Example:
#   /entity-information/v3/entities?api_key=...&ueiSAM=J1BNLBGL8G67&includeSections=entityRegistration,coreData
# Valid includeSections: entityRegistration, coreData, assertions, pointsOfContact, All
# Do NOT use exclusions/entityList as sections (HTTP 400). Use exclusionStatusFlag instead.
# Keys expire every ~90 days; regenerate on SAM if rejected
SAM_API_KEY=
