{
  "name": "grant-fraud-watch",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Friendly USAspending grant explorer with Benford's Law fraud heuristics",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "tsx server/index.ts",
    "test:benford": "tsx server/benford.test.ts",
    "docker:build": "docker build -t grant-fraud-watch .",
    "docker:run": "docker run --rm -p 3001:3001 --env-file .env grant-fraud-watch"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.15",
    "concurrently": "^9.2.0",
    "typescript": "^5.8.3"
  }
}
