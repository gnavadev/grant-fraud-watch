# Dependencies
node_modules/
client/node_modules/
**/node_modules/

# Build output
dist/
server/dist/
client/dist/
build/
*.tsbuildinfo

# Local data / runtime cache (API responses, UEI lookups, SAM extracts)
.cache/
client/.cache/
.cache/sam/
# Optional local copy of large entity DB under data/ (prefer Release in prod)
data/sam/entities.sqlite
data/sam/*.zip
data/sam/*.dat
# Bulk offline downloads (USAspending archive + FAC CSVs + parquet)
data/bulk/raw/
data/bulk/parquet/
data/bulk/duckdb/
data/bulk/probe/
data/bulk/checkpoint.json
tmp/
temp/
*.tmp

# Environment & secrets — never commit real keys
.env
.env.*
!.env.example
.env.local
.env.*.local
.env.development
.env.production
.env.staging
*.pem
*.key
*credentials*
*secret*

# Logs & debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~

# Test / coverage
coverage/
.nyc_output/

# Python (optional local ML leftovers)
__pycache__/
*.py[cod]
.venv/
venv/
.env.venv/

# Docker local artifacts
*.tar

# Local deploy / platform state
.railway/
.render/
.fly/
.vercel/
.netlify/

# Optional local notes / screenshots
*.pem
*.key
secrets/
